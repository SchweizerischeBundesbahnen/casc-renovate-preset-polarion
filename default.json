{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Base Renovate preset for Polarion repositories maintained by the SBB Polarion Team",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":enablePreCommit"
  ],
  "dependencyDashboard": true,
  "automergeType": "branch",
  "platformAutomerge": true,
  "prCreation": "status-success",
  "internalChecksFilter": "strict",
  "rebaseWhen": "behind-base-branch",
  "minimumReleaseAge": "3 days",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": [
      "before 4am on monday"
    ],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Automerge non-major updates (minor, patch, pin, digest)",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Major updates require manual review (potential breaking changes)",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Automerge GitHub Actions updates including major versions",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "description": "Automerge pre-commit updates including major versions (ignoreTests: low-risk tooling)",
      "matchManagers": [
        "pre-commit"
      ],
      "automerge": true,
      "ignoreTests": true
    },
    {
      "description": "Vulnerability alerts get highest priority to jump rate limit queue (prHourlyLimit/prConcurrentLimit)",
      "matchCategories": [
        "security"
      ],
      "prPriority": 99
    }
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "automerge": false,
    "minimumReleaseAge": "0 days"
  }
}
